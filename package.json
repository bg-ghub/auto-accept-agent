{
    "name": "auto-accept-agent",
    "displayName": "Auto Accept Agent",
    "description": "Automatically accepts Antigravity agent steps, terminal commands, and suggestions. Simple, safe, and private.",
    "version": "3.4.0",
    "publisher": "bg-ghub",
    "icon": "media/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/bg-ghub/auto-accept-agent"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "antigravity",
        "ai",
        "auto-accept",
        "agent"
    ],
    "engines": {
        "vscode": "^1.60.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "auto-accept.toggle",
                "title": "Auto Accept: Toggle ON/OFF"
            },
            {
                "command": "auto-accept.editBannedCommands",
                "title": "Auto Accept: Edit Banned Commands"
            },
            {
                "command": "auto-accept.resetBannedCommands",
                "title": "Auto Accept: Reset Banned Commands"
            },
            {
                "command": "auto-accept.discoverCommands",
                "title": "Auto Accept: Discover Antigravity Commands"
            },
            {
                "command": "auto-accept.openQuickSettings",
                "title": "Auto Accept: Quick Settings"
            },
            {
                "command": "auto-accept.diagnostics",
                "title": "Auto Accept: Run Diagnostics"
            },
            {
                "command": "auto-accept.showStatus",
                "title": "Auto Accept: Show Patch Status"
            },
            {
                "command": "auto-accept.applyPatch",
                "title": "Auto Accept: Apply Auto-Run Fix"
            },
            {
                "command": "auto-accept.revertPatch",
                "title": "Auto Accept: Revert Auto-Run Fix"
            },
            {
                "command": "auto-accept.cdpStatus",
                "title": "Auto Accept: CDP Status"
            }
        ],
        "keybindings": [
            {
                "command": "auto-accept.toggle",
                "key": "ctrl+alt+shift+u",
                "mac": "cmd+alt+shift+u"
            },
            {
                "command": "auto-accept.openQuickSettings",
                "key": "ctrl+alt+shift+s",
                "mac": "cmd+alt+shift+s"
            }
        ],
        "configuration": {
            "title": "Auto Accept Agent",
            "properties": {
                "auto-accept.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable auto-accept functionality"
                },
                "auto-accept.pollingInterval": {
                    "type": "number",
                    "default": 500,
                    "minimum": 100,
                    "maximum": 5000,
                    "description": "Polling interval in milliseconds (100-5000)"
                },
                "auto-accept.acceptAgentSteps": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-accept agent steps (tool calls, file edits, etc.)"
                },
                "auto-accept.acceptTerminalCommands": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-accept terminal/shell commands"
                },
                "auto-accept.acceptSuggestions": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-accept inline code suggestions"
                },
                "auto-accept.acceptEditBlocks": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-accept code edit blocks"
                },
                "auto-accept.acceptAll": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-accept all file changes at once (Accept All button)"
                },
                "auto-accept.acceptRunCommands": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-accept 'Run command?' dialogs (run agent commands in terminal)"
                },
                "auto-accept.autoRetryOnError": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically retry when agent errors occur (may cause focus issues)"
                },
                "auto-accept.retryBaseDelay": {
                    "type": "number",
                    "default": 1000,
                    "minimum": 500,
                    "maximum": 10000,
                    "description": "Initial delay before first retry in milliseconds"
                },
                "auto-accept.retryMaxDelay": {
                    "type": "number",
                    "default": 60000,
                    "minimum": 5000,
                    "maximum": 300000,
                    "description": "Maximum delay cap for exponential backoff in milliseconds"
                },
                "auto-accept.jitterEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Add randomization to retry timing (prevents thundering herd)"
                },
                "auto-accept.maxRetryAttempts": {
                    "type": "number",
                    "default": 5,
                    "minimum": 1,
                    "maximum": 20,
                    "description": "Maximum retry attempts before cooldown"
                },
                "auto-accept.bannedCommands": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "rm -rf /",
                        "rm -rf ~",
                        "rm -rf *",
                        "format c:",
                        "del /f /s /q",
                        "rmdir /s /q",
                        ":(){:|:&};:",
                        "dd if=",
                        "mkfs.",
                        "> /dev/sda",
                        "chmod -R 777 /",
                        "sudo rm -rf",
                        "shutdown",
                        "reboot"
                    ],
                    "description": "List of dangerous command patterns to block (supports regex with /pattern/ syntax)"
                },
                "auto-accept.cdpPort": {
                    "type": "number",
                    "default": 9333,
                    "minimum": 1024,
                    "maximum": 65535,
                    "description": "CDP remote debugging port (default 9333 to avoid conflict with AG Browser Control on 9222). Launch AG with --remote-debugging-port=PORT."
                },
                "auto-accept.autoRetryEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-click Retry and Continue buttons when the cascade agent hits errors (circuit-breaker: max 3 per 60s)"
                },
                "auto-accept.blockedCdpCommands": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Terminal commands to block via CDP (word-boundary matching). The Run button will be disabled for these."
                },
                "auto-accept.allowedCdpCommands": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "If set, ONLY these terminal commands are auto-run via CDP (whitelist mode)."
                }
            }
        }
    },
    "dependencies": {
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@electron/asar": "^4.2.0"
    }
}
